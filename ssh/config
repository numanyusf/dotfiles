# 1Password SSH agent for all hosts
Host *
	IdentityAgent ~/.1password/agent.sock

# --- CSC (Finnish supercomputing) ---
Host lumi
	HostName lumi.csc.fi
	User xcnuyo
	IdentityFile ~/.ssh/csc.pub
	IdentitiesOnly yes

Host puhti
	HostName puhti.csc.fi
	User xcnuyo
	ForwardAgent yes
	MACs hmac-sha2-512

Host roihu
	HostName roihu-gpu.csc.fi
	User xcnuyo
	IdentityFile ~/.ssh/csc.pub
	CertificateFile ~/.ssh/csc-cert.pub
	IdentitiesOnly yes

# --- Personal / other ---
Host hetzner
	HostName 204.168.134.3
	User numan

Host imhosting
	HostName imhosting.local
	User numan

