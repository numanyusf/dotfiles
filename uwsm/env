# Changes require a restart to take effect.

# Ensure Omarchy bins are in the path. ~/.local/bin comes first so user
# overrides win over Omarchy's bundled bins (e.g. omarchy-powerprofiles-init
# -> always balanced instead of performance-on-AC).
export OMARCHY_PATH=$HOME/.local/share/omarchy
export PATH=$HOME/.local/bin:$OMARCHY_PATH/bin:$PATH

# Set default terminal and editor
source ~/.config/uwsm/default

# Activate mise if present on the system
omarchy-cmd-present mise && eval "$(mise activate bash --shims)"
